#!/usr/bin/env python3
"""Canon-Mnemonic-Guard Dashboard — CLI launcher.

Usage:
  cmg dashboard     Start the web dashboard at localhost:8765
  cmg dashboard -p 8766   Use port 8766
"""

import sys, os, http.server

PORT = 8765
if len(sys.argv) > 2 and sys.argv[1] == '-p':
    PORT = int(sys.argv[2])

# Add dashboard dir to path
dashboard_dir = os.path.dirname(os.path.abspath(__file__))
if dashboard_dir not in sys.path:
    sys.path.insert(0, dashboard_dir)

import server

print(f'Canon-Mnemonic-Guard Dashboard → http://localhost:{PORT}')
print(f'Press Ctrl+C to stop')
s = http.server.HTTPServer(('127.0.0.1', PORT), server.DashboardHandler)
try:
    s.serve_forever()
except KeyboardInterrupt:
    print('\nStopped')
    s.server_close()
